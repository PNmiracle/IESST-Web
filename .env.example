APP_PORT=8080
MYSQL_PORT=3307

DB_PASSWORD=please-change-db-password
MYSQL_ROOT_PASSWORD=please-change-root-password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-admin-password
ADMIN_DISPLAY_NAME=IESST 管理员

# Generate independently: openssl rand -base64 32
PII_ENCRYPTION_KEY=replace-with-32-byte-base64-key
PII_LOOKUP_KEY=replace-with-another-32-byte-base64-key

# Alibaba Cloud OSS private bucket. Prefer RAM credentials limited to this bucket/prefix.
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=replace-with-private-bucket
OSS_ACCESS_KEY_ID=replace-with-ram-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
OSS_MANUSCRIPT_PREFIX=manuscripts
